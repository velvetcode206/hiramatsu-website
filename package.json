    "@semantic-release/release-notes-generator": "^14.1.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
